# ===== LLM =====
# Select one provider and set key + base URL accordingly.
# Uncomment the active lines and leave the others commented.

# Ark / DashScope
# ARK_API_KEY="sk-xxx"
# MODEL="qwen3.6-plus"
# BASE_URL="https://coding.dashscope.aliyuncs.com/v1"

# Zhipu GLM
ARK_API_KEY="your-glm-api-key"
MODEL="glm-5"
GRADE_MODEL="glm-5.1"
FAST_MODEL="glm-4.7"
BASE_URL="https://open.bigmodel.cn/api/coding/paas/v4"

# ===== Dense embeddings (local model, GPU first via A1/auto) =====
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=auto
DENSE_EMBEDDING_DIM=1024

# ===== Rerank (local CrossEncoder; K2 uses forced 80-candidate CE) =====
RAG_RERANK_POLICY=force
RAG_RERANK_ROUTER=rules_then_llm_shadow

RERANK_CAPABILITY_ENABLED=true
RERANK_AVAILABLE_MODEL=BAAI/bge-reranker-v2-m3
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_PROVIDER=local
RERANK_DEVICE=auto
RERANK_TORCH_DTYPE=float16

# ===== Milvus =====
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_COLLECTION=embeddings_collection_v3_quality
RAG_INDEX_PROFILE=v3_quality
RAG_K=K2
RAG_I=I2
RAG_M=M0
RAG_A=A1
BM25_STATE_PATH=data/bm25_state_v3_quality.json
EVAL_RETRIEVAL_TEXT_MODE=title_context_filename

# ===== Database / Cache =====
DATABASE_URL=postgresql+psycopg2://postgres:postgres@127.0.0.1:5433/langchain_app
FALLBACK_DATABASE_URL=sqlite:///data/superhermes.db
REDIS_URL=redis://127.0.0.1:6379/0

# ===== Auth =====
JWT_SECRET_KEY=your-jwt-secret-key
ADMIN_INVITE_CODE=your-admin-invite-code
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
PASSWORD_PBKDF2_ROUNDS=310000
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://127.0.0.1:5173,http://localhost:5173

# ===== BM25 sparse statistics persistence =====
# BM25_STATE_PATH=/path/to/bm25_state.json

# ===== RAG evaluation / tuning =====
# RAG_FALLBACK_ENABLED=false             # Experimental: fallback disabled by default
# RAG_FALLBACK_TIMEOUT_SECONDS=6          # Fallback timeout in seconds (experimental)
# RAG_FALLBACK_USE_FAST_MODEL=true        # Use FAST_MODEL for fallback LLM calls (experimental)
# STRUCTURE_RERANK_ENABLED=true
# CONFIDENCE_GATE_ENABLED=false           # Experimental: gate disabled by default
# STRUCTURE_RERANK_ROOT_WEIGHT=0.3
# SAME_ROOT_CAP=2
# LOW_CONF_TOP_MARGIN=0.05
# LOW_CONF_ROOT_SHARE=0.45
# LOW_CONF_TOP_SCORE=0.20
# ENABLE_ANCHOR_GATE=true

# ===== QueryPlan + doc scope retrieval =====
# DOC_SCOPE_MATCH_FILTER=0.85            # Threshold for scoped filter mode
# DOC_SCOPE_MATCH_BOOST=0.60             # Threshold for boost mode
# DOC_SCOPE_GLOBAL_RESERVE_WEIGHT=0.2    # Weight for global reserve in scoped retrieval
# DOC_SCOPE_FILENAME_REGISTRY_REFRESH_SECONDS=600

# ===== Heading lexical scoring =====
# HEADING_LEXICAL_ENABLED=false          # Experimental
# HEADING_LEXICAL_WEIGHT=0.20            # Alpha for heading lexical score

# ===== Rerank pair enrichment =====
# RERANK_PAIR_ENRICHMENT_ENABLED=false   # Enrich rerank input with filename/section/page

# ===== Tools =====
AMAP_WEATHER_API=https://restapi.amap.com/v3/weather/weatherInfo
AMAP_API_KEY=your-amap-api-key

HF_TOKEN=your-huggingface-token

LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your-langsmith-api-key

# OPENAI-compatible (same backend as ARK above)
# OPENAI_API_KEY="sk-xxx"
# OPENAI_BASE_URL="https://coding.dashscope.aliyuncs.com/v1"
OPENAI_API_KEY="your-openai-api-key"
OPENAI_BASE_URL="your-openai-base-url"

# ===== uv run uvicorn backend.app:app --host 127.0.0.1 --port 8001 --reload =====

# Anthropic (alternative provider)
# ANTHROPIC_API_KEY="sk-xxx"
# ANTHROPIC_MODEL="qwen3.6-plus"
# ANTHROPIC_BASE_URL="https://coding.dashscope.aliyuncs.com/apps/anthropic"

# RAG fallback / confidence gate experiments
CONFIDENCE_GATE_ENABLED=false
RAG_FALLBACK_ENABLED=false
RAG_FALLBACK_TIMEOUT_SECONDS=6
RAG_FALLBACK_USE_FAST_MODEL=true

# RAG v4 staged retrieval experiments
QUERY_PLAN_ENABLED=true
DOC_SCOPE_MATCH_FILTER=0.50
DOC_SCOPE_MATCH_BOOST=0.35
DOC_SCOPE_GLOBAL_RESERVE_WEIGHT=0.15
HEADING_LEXICAL_ENABLED=true
HEADING_LEXICAL_WEIGHT=0.15
RERANK_PAIR_ENRICHMENT_ENABLED=true
RERANK_SCORE_FUSION_ENABLED=true
RERANK_FUSION_RERANK_WEIGHT=0.65
RERANK_FUSION_RRF_WEIGHT=0.20
RERANK_FUSION_SCOPE_WEIGHT=0.10
RERANK_FUSION_METADATA_WEIGHT=0.05
RAG_CANDIDATE_K=120
RERANK_TOP_N=30
RERANK_INPUT_K_GPU=80
RERANK_INPUT_K_CPU=30
RERANK_POLICY_FULL_CE_INPUT_K=80
MILVUS_SEARCH_EF=160
MILVUS_SPARSE_DROP_RATIO=0.1
MILVUS_RRF_K=80
STRUCTURE_RERANK_ENABLED=true
SAME_ROOT_CAP=3
ENABLE_ANCHOR_GATE=false
RAG_MODE_SHADOW_ENABLED=false
RAG_MODE_ROUTING_ENABLED=false
RAG_FAST_ENABLED=false
RAG_PLAN_EXECUTION_ENABLED=false
