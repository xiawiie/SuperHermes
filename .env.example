ARK_API_KEY=
MODEL=
GRADE_MODEL=
FAST_MODEL=
BASE_URL=

# Embeddings
# EMBEDDING_PROVIDER=local    # local (HuggingFace) or ollama
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
# EMBEDDING_BASE_URL=http://localhost:11434  # only for ollama
DENSE_EMBEDDING_DIM=1024

# Rerank (optional)
RERANK_MODEL=
RERANK_BINDING_HOST=
RERANK_API_KEY=

# Milvus (optional for quick local boot)
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_COLLECTION=embeddings_collection

# Database / cache
DATABASE_URL=postgresql+psycopg2://postgres:postgres@127.0.0.1:5433/langchain_app
FALLBACK_DATABASE_URL=sqlite:///data/superhermes.db
REDIS_URL=redis://127.0.0.1:6379/0

# Auth
JWT_SECRET_KEY=replace-with-strong-random-secret
ADMIN_INVITE_CODE=superhermes-admin-2026
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
PASSWORD_PBKDF2_ROUNDS=310000

# BM25 persistence
# BM25_STATE_PATH=data/bm25_state.json

# RAG evaluation / tuning
# EVAL_RETRIEVAL_TEXT_MODE=title_context  # title_context or raw; requires reindex
# STRUCTURE_RERANK_ENABLED=true
# CONFIDENCE_GATE_ENABLED=true
# STRUCTURE_RERANK_ROOT_WEIGHT=0.3
# SAME_ROOT_CAP=2
# LOW_CONF_TOP_MARGIN=0.05
# LOW_CONF_ROOT_SHARE=0.45
# LOW_CONF_TOP_SCORE=0.20
# ENABLE_ANCHOR_GATE=true
